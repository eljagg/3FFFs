# Anthropic (for AI Tutor)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Neo4j Aura
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=your_instance_id
NEO4J_PASSWORD=your_aura_password
NEO4J_DATABASE=your_instance_id

# Auth0 (server-side — used to verify incoming JWTs)
AUTH0_DOMAIN=3fffs-training.us.auth0.com
AUTH0_AUDIENCE=https://api.3fffs.app

# Server config
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Client config (VITE_* vars are baked into the frontend at build time)
VITE_API_URL=http://localhost:3001
VITE_AUTH0_DOMAIN=3fffs-training.us.auth0.com
VITE_AUTH0_CLIENT_ID=Yn45UW1KoGsz1390qph1r21RBK8yXZni
VITE_AUTH0_AUDIENCE=https://api.3fffs.app
